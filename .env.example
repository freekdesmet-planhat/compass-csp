# ── Frontend (the ONLY public/client-side env vars) ─────────────────────────
# Leave both blank to run the app in DEMO MODE (fully explorable, no backend).
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# ── Edge Function secrets (Supabase → Project Settings → Edge Functions) ─────
# These are NEVER bundled into the client. Set with `supabase secrets set …`.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# AI (Anthropic) — model ids in env so they can be upgraded without code changes
ANTHROPIC_API_KEY=
AI_MODEL_REASONING=claude-sonnet-4-6
AI_MODEL_FAST=claude-haiku-4-5

# Planhat one-time migration (scripts/migrate-planhat.ts)
PLANHAT_API_TOKEN=
MIGRATE_DIMENSION_IDS=

# HubSpot
HUBSPOT_PRIVATE_APP_TOKEN=
HUBSPOT_RENEWAL_PIPELINE_ID=
HUBSPOT_EXPANSION_PIPELINE_ID=
HUBSPOT_WRITEBACK=true

# Fathom
FATHOM_API_KEY=
FATHOM_WEBHOOK_SECRET=

# Aircall
AIRCALL_API_ID=
AIRCALL_API_TOKEN=
AIRCALL_WEBHOOK_TOKEN=

# Outreach
OUTREACH_CLIENT_ID=
OUTREACH_CLIENT_SECRET=
OUTREACH_REDIRECT_URI=

# Org-wide
ORG_EMAIL_DOMAIN=planhat.com
ORG_TIMEZONE=Europe/Amsterdam
STORE_EMAIL_BODIES=false
APP_URL=http://localhost:5173
